VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key

# Server only: non usare mai queste variabili con prefisso VITE_.
SUPABASE_SERVICE_ROLE_KEY=your-server-side-service-role-key

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.it/api/google/callback
GOOGLE_OAUTH_STATE_SECRET=generate-a-long-random-string
GOOGLE_CALENDAR_ID=primary

# Fatturazione esterna
INVOICING_PROVIDER=fatture-in-cloud
FATTURE_IN_CLOUD_TOKEN=your-fatture-in-cloud-oauth-token
FATTURE_IN_CLOUD_COMPANY_ID=your-company-id
FATTURE_IN_CLOUD_VAT_ID=0
